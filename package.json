{
  "name": "react-native-manager",
  "displayName": "React Native Manager",
  "description": "Full-featured React Native project manager with Expo/CLI scaffolding, UI library setup, script runner, and component generator",
  "version": "0.1.0",
  "publisher": "aditya-prakash",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Snippets",
    "Extension Packs"
  ],
  "keywords": [
    "react-native",
    "expo",
    "mobile",
    "ui-library",
    "scaffold",
    "generator",
    "setup"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Aditya-Prakash14/-RN-Zone"
  },
  "bugs": {
    "url": "https://github.com/Aditya-Prakash14/-RN-Zone/issues"
  },
  "homepage": "https://github.com/Aditya-Prakash14/-RN-Zone#readme",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rnManager",
          "title": "RN Manager",
          "icon": "resources/rn-icon.svg"
        }
      ]
    },
    "views": {
      "rnManager": [
        {
          "type": "webview",
          "id": "rnManager.dashboard",
          "name": "Dashboard"
        }
      ]
    },
    "commands": [
      {
        "command": "rnManager.createProject",
        "title": "RN: Create New Project"
      },
      {
        "command": "rnManager.installUILibrary",
        "title": "RN: Install UI Library"
      },
      {
        "command": "rnManager.runScript",
        "title": "RN: Run Script"
      },
      {
        "command": "rnManager.generateComponent",
        "title": "RN: Generate Component"
      },
      {
        "command": "rnManager.generateScreen",
        "title": "RN: Generate Screen"
      },
      {
        "command": "rnManager.openDashboard",
        "title": "RN: Open Dashboard"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "rnManager.generateComponent",
          "when": "explorerResourceIsFolder",
          "group": "rnManager"
        },
        {
          "command": "rnManager.generateScreen",
          "when": "explorerResourceIsFolder",
          "group": "rnManager"
        }
      ]
    },
    "configuration": {
      "title": "React Native Manager",
      "properties": {
        "rnManager.packageManager": {
          "type": "string",
          "enum": [
            "npm",
            "yarn",
            "bun"
          ],
          "default": "npm",
          "description": "Package manager to use"
        },
        "rnManager.defaultProjectType": {
          "type": "string",
          "enum": [
            "expo",
            "cli"
          ],
          "default": "expo",
          "description": "Default project type when creating new projects"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
